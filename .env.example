# AI Cricket Coach — local development environment variables
#
# Copy this file to .env and customise values before running:
#   cp .env.example .env
#
# WARNING: Never commit .env with real credentials.
# These defaults are for local development only.

# MinIO object storage credentials
# MUST be changed for any non-local/shared deployment.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
